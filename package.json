{
  "name": "rhsistema-backend",
  "version": "0.1.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:homolog": "DB_SCHEMA=rs_admissao_homolog node server.js",
    "start:prod": "DB_SCHEMA=rs_admissao_prod node server.js",
    "dev": "nodemon server.js",
    "dev:homolog": "DB_SCHEMA=rs_admissao_homolog nodemon server.js",
    "dev:prod": "DB_SCHEMA=rs_admissao_prod nodemon server.js",
    "db:init": "node scripts/init-db.js",
    "db:test": "node scripts/test-db-connection.js",
    "setup:production": "node scripts/setup-production.js",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "migrate:dry-run": "node scripts/migrate.js --dry-run",
    "migrate:up": "node scripts/migrate.js",
    "migrate:up:homolog": "DB_SCHEMA=rs_admissao_homolog node scripts/migrate.js",
    "migrate:up:prod": "DB_SCHEMA=rs_admissao_prod node scripts/migrate.js",
    "migrate:create": "node-pg-migrate create",
    "seed:admin": "node scripts/seed-admin.js",
    "deploy:check": "npm run db:test && npm run setup:production",
    "test": "jest --runInBand",
    "test:e2e": "jest --runInBand tests/e2e",
    "schema:map": "node scripts/map-schema-structure.js",
    "schema:migrate": "node scripts/migrate-schema-to-homolog.js",
    "schema:compare": "node scripts/compare-schemas.js",
    "schema:tools": "bash scripts/schema-tools.sh",
    "schema:check": "node scripts/check-schema.js",
    "db:fix-sequences": "node fix-all-sequences.js",
    "views:regenerate": "node scripts/regenerate-views.js",
    "views:regenerate:homolog": "node scripts/regenerate-views.js --homolog",
    "views:regenerate:prod": "node scripts/regenerate-views.js --prod"
  },
  "dependencies": {
    "@api/gupy-api": "file:.api/apis/gupy-api",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.0",
    "bcryptjs": "^3.0.2",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "googleapis": "^164.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.6.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.3",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "swagger-ui-express": "^4.6.3",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "nock": "^14.0.10",
    "node-pg-migrate": "^8.0.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
