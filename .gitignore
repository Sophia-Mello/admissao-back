# ============================================================================
# R&S ADMISSÃO BACKEND - Git Ignore
# ============================================================================

# ----------------------------------------------------------------------------
# Environment & Secrets (CRÍTICO - nunca commitar!)
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.1password
*.pem
*.key
*.ppk
credentials*.json

# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------------------------------------------
# Build & Coverage
# ----------------------------------------------------------------------------
dist/
build/
coverage/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------------------------
# Runtime & Temporary
# ----------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/
*.tmp

# ----------------------------------------------------------------------------
# Database files
# ----------------------------------------------------------------------------
*.sqlite
*.db

# ----------------------------------------------------------------------------
# Data files (devem ir para storage/banco)
# ----------------------------------------------------------------------------
*.csv
*.xlsx
*.xls

# ----------------------------------------------------------------------------
# Cleanup backups
# ----------------------------------------------------------------------------
.cleanup-backup-*/

# ----------------------------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# Lock files de editores de planilha
.~lock.*

# ----------------------------------------------------------------------------
# OS Generated
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Scripts temporários/one-off (não versionar)
# ----------------------------------------------------------------------------
scripts/retry-pre-employees.js

# ----------------------------------------------------------------------------
# Scripts temporários na raiz (padrões de debug/teste)
# ----------------------------------------------------------------------------
# Estes padrões se aplicam APENAS à raiz do projeto
/test-*.js
/debug-*.js
/check-*.js
/fix-*.js
/analyze-*.js
/execute-*.js
/verify-*.js
/monitoring-*.js
/tmp_*.js
/find-*.js
/data-cleanup-*.js

# Git backups
.git-backup-*/

# Claude Code local settings (personal preferences)
.claude/settings.local.json
